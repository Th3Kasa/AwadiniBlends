# Square Web Payments SDK
# Get credentials at https://developer.squareup.com
NEXT_PUBLIC_SQUARE_APP_ID=sq0idp-your-production-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=YOUR_LOCATION_ID
SQUARE_ACCESS_TOKEN=YOUR_PRODUCTION_ACCESS_TOKEN
SQUARE_LOCATION_ID=YOUR_LOCATION_ID
SQUARE_ENVIRONMENT=production

# Web3Forms — get your free access key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=YOUR_WEB3FORMS_ACCESS_KEY

# Brevo (email list) — free unlimited contacts at https://brevo.com
# Sign up → Settings → API Keys → Generate a new API key
# Your customer emails are automatically added after each order
BREVO_API_KEY=YOUR_BREVO_API_KEY

# Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.com
